# Copy to .env (gitignored) and fill in your credentials.
# Used by scripts/build_dmg.sh and scripts/release.sh.

# --- Notarization credentials ---
# Option A: Apple ID + app-specific password (simplest)
#   Generate the password at https://appleid.apple.com/account/manage → "App-Specific Passwords"
APPLE_ID=you@example.com
APPLE_TEAM_ID=GVXC5FQ2RP
APPLE_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Option B (preferred for security): pre-stored notarytool keychain profile.
# One-time setup:
#   xcrun notarytool store-credentials \
#       --apple-id you@example.com \
#       --team-id GVXC5FQ2RP \
#       --password xxxx-xxxx-xxxx-xxxx \
#       Tock-Notary
# Then uncomment the next line (and you can delete the three above):
# NOTARY_PROFILE=Tock-Notary

# --- Code-signing identity (optional) ---
# Defaults to "Developer ID Application" — fine if you have exactly one such cert
# in your keychain. If you have multiple, pin the exact one:
# DEVELOPER_ID_APPLICATION="Developer ID Application: Tim Moreton (GVXC5FQ2RP)"
